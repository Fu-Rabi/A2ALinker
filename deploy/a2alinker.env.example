NODE_ENV=production
BROKER_STORE=redis
REDIS_URL=redis://127.0.0.1:6379/15
LOOKUP_HMAC_KEY=replace-with-at-least-32-random-bytes
TRUST_PROXY=1
HTTP_BIND_HOST=127.0.0.1
HTTP_PORT=3000
PUBLIC_HOST=broker.a2alinker.net
ENABLE_SSH=false

# Optional
# ADMIN_TOKEN=replace-with-random-admin-token
# WAIT_TIMEOUT_MS=110000
# DRAIN_TIMEOUT_MS=25000
# TOKEN_TTL_MS=900000
# CODE_TTL_MS=900000
# WAITING_ROOM_TTL_MS=900000
# SESSION_IDLE_TTL_MS=1800000
# WAITER_TTL_MS=115000
# INBOX_TTL_MS=1800000
# LOOP_COUNTER_TTL_MS=300000

# Reverse proxy is the default production shape.
# Direct in-process HTTPS is disabled in production unless you also set:
# ALLOW_DIRECT_HTTPS_PROD=true
# HTTPS_KEY_PATH=/path/to/privkey.pem
# HTTPS_CERT_PATH=/path/to/fullchain.pem
