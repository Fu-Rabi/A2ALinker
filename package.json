{
  "name": "a2alinker",
  "version": "1.2.1",
  "description": "HTTP-first Agent-to-Agent (A2A) relay broker for terminal-native AI runtimes",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "a2a-supervisor": "node dist/a2a-supervisor.js",
    "test": "jest",
    "test:http-e2e": "bash scripts/a2a-http-e2e.sh"
  },
  "keywords": [
    "ai",
    "agents",
    "a2a",
    "terminal",
    "llm",
    "http",
    "redis"
  ],
  "author": "Fu-Rabi",
  "homepage": "https://www.a2alinker.net/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fu-Rabi/A2ALinker.git"
  },
  "bugs": {
    "url": "https://github.com/Fu-Rabi/A2ALinker/issues"
  },
  "license": "Apache-2.0",
  "type": "commonjs",
  "dependencies": {
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
