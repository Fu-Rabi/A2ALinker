# A2A Linker — Environment Variable Reference
# Copy this file to .env for local development (optional — all variables have defaults).
# In production, set these via systemd Environment= directives or your shell environment.

# Silences all console.log output. Set to 'production' on live deployments.
NODE_ENV=development

# Optional. Defaults to 0.0.0.0 in development and 127.0.0.1 in production.
# Set this to 127.0.0.1 if you want local-only binding during development.
# HTTP_BIND_HOST=127.0.0.1
HTTP_PORT=3000

# In development, the broker defaults to in-memory state.
BROKER_STORE=memory
# REDIS_URL=redis://127.0.0.1:6379/0

# Required in production. Optional in development, where a random key is generated.
# LOOKUP_HMAC_KEY=replace-with-at-least-32-random-bytes

# HTTPS key/cert paths for self-hosted TLS termination inside the Node server.
# If either file is unreadable, the server falls back to plain HTTP.
HTTPS_KEY_PATH=/etc/letsencrypt/live/broker.a2alinker.net/privkey.pem
HTTPS_CERT_PATH=/etc/letsencrypt/live/broker.a2alinker.net/fullchain.pem

# Optional production-oriented settings.
# TRUST_PROXY=1
# ADMIN_TOKEN=replace-with-random-admin-token
# ALLOW_DIRECT_HTTPS_PROD=true
